{
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/submit",
      "destination": "/backend/app.py"
    },
    {
      "source": "/style.css",
      "destination": "/style.css"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
